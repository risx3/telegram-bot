# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id

# PostgreSQL — used by both the bot and the postgres container
POSTGRES_DB=depositbot
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://user:password@postgres:5432/depositbot

# Redis
REDIS_URL=redis://redis:6379/0

# Webhook security (required — bot refuses requests if this is missing)
SMS_WEBHOOK_SECRET=test123

# App
PORT=8000
LOG_LEVEL=INFO
QR_CODE_PATH=assets/qr_code.png
